generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RoleKey {
  DEALER_OWNER
  DEALER_BUYER
  VENDOR_MANAGER
  ADMIN
}

enum VehicleStatus {
  NEW
  ANALYZED
  NEGOTIATING
  APPROVAL_PENDING
  PURCHASED
  RECONDITIONING
  SOLD
  PASSED
}

enum RecommendationKey {
  BUY
  NEGOTIATE
  WAIT
  PASS
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  NEGOTIATING
  WON
  LOST
}

enum TaskStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum CommunicationChannel {
  EMAIL
  SMS
  PHONE
  IN_PERSON
  OTHER
}

enum CommunicationDirection {
  INBOUND
  OUTBOUND
}

enum InspectionCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum FinancingStatus {
  PENDING
  APPROVED
  DECLINED
  WITHDRAWN
}

enum SaleDocumentType {
  PURCHASE_AGREEMENT
  BUYER_DISCLOSURE
  DELIVERY_CHECKLIST
  OTHER
}

enum SignatureStatus {
  UNSIGNED
  AWAITING_PROVIDER
  SIGNED
}

enum InventoryStage {
  ACQUISITION
  PURCHASE
  INSPECTION
  RECONDITIONING
  PRICING
  PUBLISHING
  SOLD
}

model Organization {
  id                String                  @id @default(cuid())
  name              String
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  memberships       Membership[]
  vehicles          Vehicle[]
  auditLogs         AuditLog[]
  activityLogs      ActivityLog[]
  customers         Customer[]
  leads             Lead[]
  tasks             Task[]
  notes             Note[]
  communications    CommunicationLogEntry[]
  appointments      Appointment[]
  emailTemplates    EmailTemplate[]
  inspectionReports InspectionReport[]
  priceRecords      PriceRecord[]
  listings          Listing[]
  sales             Sale[]
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  firstName               String
  lastName                String
  passwordHash            String
  emailVerifiedAt         DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  memberships             Membership[]
  auditEntries            AuditLog[]               @relation("AuditActor")
  sessions                Session[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           RoleKey
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId, role])
}

model Vehicle {
  id                String             @id @default(cuid())
  organizationId    String
  vin               String             @unique
  year              Int?
  make              String?
  model             String?
  trim              String?
  mileage           Int?
  status            VehicleStatus      @default(NEW)
  workflowState     String?
  inventoryStage    InventoryStage     @default(ACQUISITION)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vinAnalyses       VinAnalysis[]
  leads             Lead[]
  inspectionReports InspectionReport[]
  priceRecords      PriceRecord[]
  listings          Listing[]
  sales             Sale[]

  @@index([organizationId, status])
}

model VinAnalysis {
  id                String             @id @default(cuid())
  vehicleId         String
  decodedPayload    Json
  manualCorrections Json?
  marketValue       Decimal?           @db.Decimal(12, 2)
  wholesaleValue    Decimal?           @db.Decimal(12, 2)
  retailValue       Decimal?           @db.Decimal(12, 2)
  transportEstimate Decimal?           @db.Decimal(12, 2)
  repairEstimate    Decimal?           @db.Decimal(12, 2)
  feesEstimate      Decimal?           @db.Decimal(12, 2)
  taxesEstimate     Decimal?           @db.Decimal(12, 2)
  projectedRoi      Decimal?           @db.Decimal(12, 2)
  confidenceScore   Float?
  riskSummary       String?
  aiExplanation     String?
  recommendation    RecommendationKey?
  workflowState     String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  vehicle           Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, createdAt])
}

model ActivityLog {
  id             String       @id @default(cuid())
  organizationId String
  actorUserId    String?
  entityType     String
  entityId       String
  type           String
  summary        String
  payload        Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  actorUserId    String?
  action         String
  entityType     String
  entityId       String
  beforeState    Json?
  afterState     Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor          User?        @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  accessTokenHash  String    @unique
  refreshTokenHash String    @unique
  rememberMe       Boolean   @default(false)
  userAgent        String?
  ipAddress        String?
  accessExpiresAt  DateTime
  refreshExpiresAt DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  lastUsedAt       DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------
// CRM
// ---------------------------------------------------------------------

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  firstName      String
  lastName       String
  email          String?
  phone          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads          Lead[]
  tasks          Task[]
  notes          Note[]
  communications CommunicationLogEntry[]
  appointments   Appointment[]
  sales          Sale[]

  @@index([organizationId])
}

model Lead {
  id             String     @id @default(cuid())
  organizationId String
  customerId     String
  vehicleId      String?
  status         LeadStatus @default(NEW)
  source         String?
  ownerUserId    String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicle        Vehicle?                @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  tasks          Task[]
  notes          Note[]
  communications CommunicationLogEntry[]
  appointments   Appointment[]

  @@index([organizationId, status])
  @@index([customerId])
}

model Task {
  id             String     @id @default(cuid())
  organizationId String
  leadId         String?
  customerId     String?
  assignedUserId String?
  title          String
  dueAt          DateTime?
  status         TaskStatus @default(PENDING)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, dueAt])
}

model Note {
  id             String   @id @default(cuid())
  organizationId String
  leadId         String?
  customerId     String?
  authorUserId   String?
  body           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model CommunicationLogEntry {
  id             String                 @id @default(cuid())
  organizationId String
  leadId         String?
  customerId     String?
  channel        CommunicationChannel
  direction      CommunicationDirection
  summary        String
  createdAt      DateTime               @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model Appointment {
  id             String            @id @default(cuid())
  organizationId String
  leadId         String?
  customerId     String?
  title          String
  scheduledAt    DateTime
  status         AppointmentStatus @default(SCHEDULED)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([organizationId, scheduledAt])
}

model EmailTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  subject        String
  body           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
}

// ---------------------------------------------------------------------
// Inventory workflows
// ---------------------------------------------------------------------

model InspectionReport {
  id               String              @id @default(cuid())
  organizationId   String
  vehicleId        String
  inspectorUserId  String?
  overallCondition InspectionCondition
  findings         Json
  createdAt        DateTime            @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([organizationId, vehicleId])
}

model PriceRecord {
  id             String   @id @default(cuid())
  organizationId String
  vehicleId      String
  price          Decimal  @db.Decimal(12, 2)
  reason         String?
  setByUserId    String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([organizationId, vehicleId, createdAt])
}

model Listing {
  id             String        @id @default(cuid())
  organizationId String
  vehicleId      String
  channel        String
  status         ListingStatus @default(DRAFT)
  publishedAt    DateTime?
  url            String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([organizationId, vehicleId])
}

// ---------------------------------------------------------------------
// Sales
// ---------------------------------------------------------------------

model Sale {
  id             String     @id @default(cuid())
  organizationId String
  vehicleId      String
  customerId     String
  salePrice      Decimal    @db.Decimal(12, 2)
  saleDate       DateTime?
  status         SaleStatus @default(PENDING)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle               Vehicle                @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  customer              Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tradeIns              TradeInVehicle[]
  financingApplications FinancingApplication[]
  documents             SaleDocument[]

  @@index([organizationId, status])
  @@index([vehicleId])
}

model TradeInVehicle {
  id             String   @id @default(cuid())
  saleId         String
  vin            String?
  year           Int?
  make           String?
  model          String?
  mileage        Int?
  appraisedValue Decimal  @db.Decimal(12, 2)
  payoffAmount   Decimal? @db.Decimal(12, 2)
  createdAt      DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

model FinancingApplication {
  id         String          @id @default(cuid())
  saleId     String
  lenderName String?
  principal  Decimal         @db.Decimal(12, 2)
  apr        Float
  termMonths Int
  status     FinancingStatus @default(PENDING)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

model SaleDocument {
  id              String           @id @default(cuid())
  saleId          String
  type            SaleDocumentType
  signatureStatus SignatureStatus  @default(UNSIGNED)
  signedAt        DateTime?
  createdAt       DateTime         @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId, type])
}
