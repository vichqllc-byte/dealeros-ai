NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dealeros
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/dealeros
# Generate a strong random secret for production, e.g.: openssl rand -base64 48
AUTH_TOKEN_SECRET=replace-with-a-32+-byte-random-secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# --- Premium vehicle-intelligence data providers (all optional) ---
# None of these are required to run the app: every feature that uses one
# of these providers falls back to a real, documented heuristic estimate
# when the corresponding key below is unset. Set a key to activate that
# provider - see lib/vin-intelligence/providers/ for the adapter that
# consumes each one.
NMVTIS_API_KEY=
CARFAX_API_KEY=
AUTOCHECK_API_KEY=
BLACKBOOK_API_KEY=
JD_POWER_API_KEY=
KBB_API_KEY=
MANHEIM_MMR_API_KEY=
EDMUNDS_API_KEY=
COPART_API_KEY=
IAAI_API_KEY=
AUTO_AUCTION_SERVICES_API_KEY=
