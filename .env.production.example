# Production environment template. Copy to .env (never commit the real
# file - it's already in .gitignore) and fill in real values, or provide
# these same variables via your platform's secrets manager.

NEXT_PUBLIC_APP_URL=https://your-domain.example.com

# Point both at your production PostgreSQL instance. DIRECT_URL is used
# for migrations and should bypass any connection pooler (e.g. PgBouncer)
# that DATABASE_URL might go through.
DATABASE_URL=postgresql://user:password@your-db-host:5432/dealeros?sslmode=require
DIRECT_URL=postgresql://user:password@your-db-host:5432/dealeros?sslmode=require

POSTGRES_PASSWORD=replace-with-a-real-strong-password

# Generate with: openssl rand -base64 48
AUTH_TOKEN_SECRET=replace-with-a-32+-byte-random-secret

# Real Stripe keys from your Stripe Dashboard (live mode for production).
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PROFESSIONAL_MONTHLY=
STRIPE_PRICE_PROFESSIONAL_ANNUAL=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_ANNUAL=

# Optional auction/marketplace integrations (required only if enabling those
# external provider routes in production).
COPART_API_URL=
COPART_API_KEY=
IAA_API_URL=
IAA_API_KEY=
MANHEIM_API_URL=
MANHEIM_API_KEY=
MARKETPLACE_POSTING_API_URL=
MARKETPLACE_POSTING_API_KEY=

# --- Premium vehicle-intelligence data providers (all optional) ---
# See .env.example for what each of these unlocks.
NMVTIS_API_KEY=
CARFAX_API_KEY=
AUTOCHECK_API_KEY=
BLACKBOOK_API_KEY=
JD_POWER_API_KEY=
KBB_API_KEY=
MANHEIM_MMR_API_KEY=
EDMUNDS_API_KEY=
IAAI_API_KEY=
AUTO_AUCTION_SERVICES_API_KEY=
ESIGN_PROVIDER_API_KEY=
